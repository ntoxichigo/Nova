    "dev": "node --import tsx/esm src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "boxen": "^8.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.0.0",
    "conf": "^13.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}

