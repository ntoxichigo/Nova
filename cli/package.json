{
  "name": "nova-cli",
  "version": "2.0.0",
  "description": "Nova AI Agent - Personal CLI (Open Source Edition)",
  "type": "module",
  "bin": { "nova": "./bin/nova.js" },
  "files": ["dist/", "bin/"],
  "keywords": ["ai", "agent", "cli", "llm", "ollama", "gpt"],
  "license": "MIT",
  "engines": { "node": ">=18" },
  "scripts": {
